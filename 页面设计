<script>
    // Calendar toggle logic - Default expanded in "spacious" view
    const toggleBtn = document.getElementById('calendar-toggle');
    const calendarContent = document.getElementById('calendar-content');
    const toggleIcon = document.getElementById('toggle-icon');
    let isExpanded = true;
    calendarContent.style.maxHeight = '500px';
    toggleIcon.style.transform = 'rotate(180deg)';

    toggleBtn.addEventListener('click', () => {
        isExpanded = !isExpanded;
        if (isExpanded) {
            calendarContent.style.maxHeight = '500px';
            toggleIcon.style.transform = 'rotate(180deg)';
        } else {
            calendarContent.style.maxHeight = '0px';
            toggleIcon.style.transform = 'rotate(0deg)';
        }
    });

    // Simple counter animation
    const counter = document.getElementById('days-counter');
    const finalValue = 624;
    let startValue = 600;
    function animate() {
        if (startValue < finalValue) {
            startValue++;
            counter.innerText = startValue;
            setTimeout(animate, 20);
        }
    }
    setTimeout(animate, 500);

    // Nav active state
    const navButtons = document.querySelectorAll('nav button');
    navButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            navButtons.forEach(b => {
                b.classList.remove('text-primary', 'bg-primary-container/15', 'rounded-2xl');
                b.classList.add('text-secondary/60');
                const span = b.querySelector('span:last-child');
                if(span) span.classList.remove('font-bold');
                const icon = b.querySelector('.material-symbols-outlined');
                if(icon) icon.style.fontVariationSettings = "'FILL' 0";
            });
            this.classList.add('text-primary', 'bg-primary-container/15', 'rounded-2xl');
            this.classList.remove('text-secondary/60');
            const span = this.querySelector('span:last-child');
            if(span) span.classList.add('font-bold');
            const activeIcon = this.querySelector('.material-symbols-outlined');
            if(activeIcon) activeIcon.style.fontVariationSettings = "'FILL' 1";
        });
    });
</script>
